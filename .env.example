# SMTP settings used by SGCN.Api locally and on Railway.
Email__Host=smtp.example.com
Email__Port=587
Email__UserName=replace-with-smtp-user
Email__Password=replace-with-smtp-password
Email__FromAddress=no-reply@example.com
Email__FromName=SGCN
Email__EnableSsl=true

# Public URL of the React application, without a trailing slash.
Frontend__BaseUrl=http://localhost:5173
